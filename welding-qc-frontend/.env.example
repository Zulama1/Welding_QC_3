# =========================
# APP CONFIG
# =========================
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# =========================
# DATABASE CONFIG
# =========================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=welding_qc
DB_USER=root
DB_PASSWORD=your_password_here

# =========================
# AUTH / SECURITY
# =========================
JWT_SECRET=your_super_secret_key_here

# =========================
# FILE UPLOADS
# =========================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# =========================
# OPTIONAL LOGGING
# =========================
LOG_LEVEL=debug
